; ACME challenge zone for _acme-challenge.internal.{DOMAIN}
; Serves DNS-01 TXT records for *.internal.{DOMAIN} wildcard cert issuance.
; The Caddy DNS module writes TXT records here and removes them afterwards.

$TTL 60
$ORIGIN _acme-challenge.internal.{DOMAIN}.

@   IN SOA ns1.{DOMAIN}. admin.{DOMAIN}. (
        2026040201  ; serial — auto-managed by Meshploy API
        3600        ; refresh
        900         ; retry
        604800      ; expire
        60          ; minimum TTL — must be low, challenges are short-lived
    )

@   IN NS  ns1.{DOMAIN}.

; TXT records are written and deleted here automatically during cert issuance.
; Example (managed by Meshploy API):
;   @   IN TXT  "abc123challengetoken"
