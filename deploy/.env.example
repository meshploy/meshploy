# ── Required ──────────────────────────────────────────────────────────────────
# Your base domain. All subdomains derive from this.
#   headscale.{DOMAIN}  → Headscale control plane
#   api.{DOMAIN}        → Meshploy API
#   app.{DOMAIN}        → Meshploy dashboard
#   *.{DOMAIN}          → deployed app routes (wildcard, via proxy)
DOMAIN=meshploy.example.com

# Public IPv4 of your gateway server (the machine running this compose stack).
# Used in CoreDNS zone files as the A record target.
PUBLIC_IP=1.2.3.4

# WireGuard mesh IP assigned to the gateway node by Headscale.
# Default is 100.64.0.1 — the first address in Headscale's default range.
# CoreDNS binds the private internal zone to this IP.
MESH_IP=100.64.0.1

# Postgres password (required, no default)
POSTGRES_PASSWORD=changeme

# JWT signing secret — use a long random string (≥ 32 chars)
# Generate: openssl rand -hex 32
JWT_SECRET=

# AES-256-GCM encryption key for secrets at rest — must be exactly 32 chars
# Generate: openssl rand -hex 16  (gives 32 hex chars)
ENCRYPTION_KEY=

# Headscale API key — generate after first start:
#   docker compose exec headscale headscale apikeys create   (Docker)
#   podman compose exec headscale headscale apikeys create   (Podman)
HEADSCALE_API_KEY=

# ── Optional (have sane defaults) ────────────────────────────────────────────
POSTGRES_DB=meshploy
POSTGRES_USER=meshploy

# Override if your API or frontend are on non-standard subdomains
API_BASE_URL=https://api.${DOMAIN}
FRONTEND_URL=https://app.${DOMAIN}

# ── Notes ─────────────────────────────────────────────────────────────────────
# 1. Copy this file to .env and fill in the required values.
#
# 2. Replace all {DOMAIN}, {PUBLIC_IP}, {MESH_IP} placeholders in:
#      deploy/coredns/Corefile
#      deploy/coredns/zones/*
#      deploy/headscale/config/config.yaml
#    Either edit manually or run:
#      export DOMAIN=... PUBLIC_IP=... MESH_IP=...
#      envsubst < coredns/Corefile.tpl > coredns/Corefile
#
# 3. Point your registrar's NS records to this server before starting CoreDNS.
#    Verify with: dig @{PUBLIC_IP} {DOMAIN} A
#
# 4. The wildcard *.{DOMAIN} Caddy block requires a DNS-01 ACME challenge for
#    TLS. Named subdomains (headscale, api, app) auto-provision via HTTP-01.
#    Wildcard TLS is optional until app routes are actively used.
