# Meshploy Caddyfile
# Caddy runs with network_mode: host so all reverse_proxy targets are localhost.
#
# TLS strategy:
#   - Named subdomains (headscale, console) use DNS-01 with CNAME delegation to
#     _acme-challenge.{DOMAIN}. Recursive resolvers follow the CNAME — no
#     resolvers override needed.
#   - *.internal uses DNS-01 with NS delegation to its own zone
#     (_acme-challenge.internal.{DOMAIN}). resolvers points CertMagic at the
#     authoritative CoreDNS directly, bypassing recursive resolver caching.
#   - Custom user domains use On-Demand TLS (HTTP-01). Caddy asks the API
#     before issuing — only domains verified by the user receive a cert.
#
# Prerequisites:
#   - DNS A records for headscale, api, console pointing to PUBLIC_IP (written by install.sh)
#   - NS delegation for {DOMAIN} pointing to this server

{
    on_demand_tls {
        # Only issue On-Demand certs for custom domains verified in Meshploy.
        # Prevents cert issuance for domains the user hasn't proved they own.
        ask http://localhost:4000/api/v1/internal/domain-check
    }
}

# ── Headscale control plane ──────────────────────────────────────────────────
headscale.{$DOMAIN} {
    tls {
        dns meshploy {
            zone_file_path /etc/coredns/zones/_acme-challenge.{$DOMAIN}
        }
    }
    reverse_proxy localhost:8085
}

# ── Meshploy API (dedicated subdomain) ──────────────────────────────────────
# All traffic → Go API on port 4000.
# Exposes /docs (Swagger UI), /api/v1/*, and SSE log endpoints.
api.{$DOMAIN} {
    tls {
        dns meshploy {
            zone_file_path /etc/coredns/zones/_acme-challenge.{$DOMAIN}
        }
    }
    reverse_proxy localhost:4000 {
        flush_interval -1
    }
}

# ── Meshploy Web UI + API ────────────────────────────────────────────────────
# /api/* → Go API, everything else → Next.js
console.{$DOMAIN} {
    tls {
        dns meshploy {
            zone_file_path /etc/coredns/zones/_acme-challenge.{$DOMAIN}
        }
    }
    handle /api/* {
        reverse_proxy localhost:4000 {
            # flush_interval -1 disables response buffering so SSE log streams
            # are forwarded to the client immediately instead of being held
            # until the connection closes.
            flush_interval -1
        }
    }
    handle {
        reverse_proxy localhost:5173
    }
}

# ── Public workload routes — wildcard ────────────────────────────────────────
# Wildcard cert covers all public service subdomains (e.g. auth-ui.{DOMAIN}).
# Uses the same DNS-01 zone file as the named subdomains above.
# Proxy reads the Host header → route cache lookup → forwards to worker mesh IP.
*.{$DOMAIN} {
    tls {
        dns meshploy {
            zone_file_path /etc/coredns/zones/_acme-challenge.{$DOMAIN}
        }
    }
    reverse_proxy localhost:8081
}

# ── Internal mesh traffic — wildcard ─────────────────────────────────────────
# Wildcard cert requires DNS-01 — uses its own NS-delegated challenge zone.
# resolvers points at the authoritative CoreDNS so CertMagic queries it
# directly (no CNAME to chase, no recursive resolver caching in the way).
# Only reachable from inside the WireGuard mesh (bound to mesh IP).
*.internal.{$DOMAIN} {
    bind {$MESH_IP}
    tls {
        dns meshploy {
            zone_file_path /etc/coredns/zones/_acme-challenge.internal.{$DOMAIN}
        }
        resolvers {$PUBLIC_IP}
    }
    reverse_proxy localhost:8081
}

# ── Custom user domains (On-Demand TLS) ──────────────────────────────────────
# Catchall for any hostname not matched by the blocks above (e.g. myapp.com).
# Caddy calls the ask endpoint before issuing a cert. Only hostnames with
# custom_domain_verified=true in the routes table get a cert — this prevents
# domain hijacking by users who register a hostname they don't control.
:443 {
    tls {
        on_demand
    }
    reverse_proxy localhost:8081
}
