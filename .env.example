# Copy this file to .env and fill in your values
# cp .env.example .env

# -------------------------------------------------------
# Database (Postgres)
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=disable
# -------------------------------------------------------
DATABASE_URL=postgres://meshploy:meshploy@localhost:5432/meshploy?sslmode=disable

# -------------------------------------------------------
# API
# -------------------------------------------------------
API_PORT=4000
JWT_SECRET=change-me-to-a-long-random-string
# Must be exactly 32 characters for AES-256. Generate with: openssl rand -hex 16
ENCRYPTION_KEY=change-me-to-32-chars-exactly!!

# -------------------------------------------------------
# Headscale
# -------------------------------------------------------
HEADSCALE_URL=http://localhost:8080
HEADSCALE_API_KEY=

# -------------------------------------------------------
# Proxy
# -------------------------------------------------------
PROXY_PORT=8081
