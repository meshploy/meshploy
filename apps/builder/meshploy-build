#!/usr/bin/env bash
# Meshploy build script — runs inside the K8s builder Job container.
# Environment variables are injected by the K8s Job spec:
#   GIT_REPO       owner/repo
#   GIT_BRANCH     branch to build
#   GIT_TOKEN      GitHub installation access token
#   BUILDER        nixpacks | railpack | dockerfile
#   IMAGE_DEST     registry/image:tag to push to
#   REGISTRY_HOST  registry hostname (for buildah login)
#   REGISTRY_USER  registry username
#   REGISTRY_PASS  registry password

set -euo pipefail

log() { echo -e "\033[1;34m[meshploy-build]\033[0m $*"; }
die() { echo -e "\033[1;31m[meshploy-build] ERROR:\033[0m $*" >&2; exit 1; }

[[ -z "${GIT_REPO:-}"    ]] && die "GIT_REPO is not set"
[[ -z "${GIT_BRANCH:-}"  ]] && die "GIT_BRANCH is not set"
[[ -z "${GIT_TOKEN:-}"   ]] && die "GIT_TOKEN is not set"
[[ -z "${IMAGE_DEST:-}"  ]] && die "IMAGE_DEST is not set"
[[ -z "${REGISTRY_HOST:-}" ]] && die "REGISTRY_HOST is not set"

BUILDER="${BUILDER:-nixpacks}"
WORKDIR="/tmp/workspace"

# ── Parse build-time env vars ─────────────────────────────────────────────────
# BUILD_ENV_VARS is a newline-separated list of KEY=VALUE pairs.
# Build arrays of flags for each builder from the non-empty, non-comment lines.
NIXPACKS_ENV_FLAGS=()
RAILPACK_EXPORTS=""
DOCKERFILE_BUILD_ARG_FLAGS=()

if [[ -n "${BUILD_ENV_VARS:-}" ]]; then
    while IFS= read -r line; do
        # Skip blank lines and comments
        [[ -z "$line" || "$line" == \#* ]] && continue
        key="${line%%=*}"
        value="${line#*=}"
        # Strip one layer of surrounding single or double quotes from the value.
        # Users often write KEY="value with spaces" — the quotes are shell syntax
        # and should not be part of the actual value passed to the build tool.
        if [[ ${#value} -ge 2 ]]; then
            first="${value:0:1}" last="${value: -1}"
            if [[ "$first" == '"' && "$last" == '"' ]] || \
               [[ "$first" == "'" && "$last" == "'" ]]; then
                value="${value:1:${#value}-2}"
            fi
        fi
        NIXPACKS_ENV_FLAGS+=(--env "${key}=${value}")
        RAILPACK_EXPORTS+="export $(printf '%q=%q' "${key}" "${value}"); "
        DOCKERFILE_BUILD_ARG_FLAGS+=(--build-arg "${key}=${value}")
    done <<< "${BUILD_ENV_VARS}"
fi

# ── Clone ─────────────────────────────────────────────────────────────────────
log "Cloning ${GIT_REPO}@${GIT_BRANCH}…"
git clone --depth=1 --branch "${GIT_BRANCH}" \
    "https://x-access-token:${GIT_TOKEN}@github.com/${GIT_REPO}.git" \
    "${WORKDIR}"
cd "${WORKDIR}"
log "Cloned successfully ($(git rev-parse --short HEAD))"

# ── Mark registry as insecure if it is HTTP ──────────────────────────────────
# buildah defaults to HTTPS. Internal mesh registries (e.g. 100.64.x.x:5000)
# are plain HTTP — add them to registries.conf so buildah doesn't upgrade to TLS.
# This covers both `buildah push` and `buildah build --cache-from`.
mkdir -p "${HOME}/.config/containers"
cat >> "${HOME}/.config/containers/registries.conf" <<EOF

[[registry]]
location = "${REGISTRY_HOST}"
insecure = true
EOF

# ── Registry login ────────────────────────────────────────────────────────────
if [[ -n "${REGISTRY_USER:-}" && -n "${REGISTRY_PASS:-}" ]]; then
    log "Logging in to ${REGISTRY_HOST}…"
    echo "${REGISTRY_PASS}" | buildah login \
        --username "${REGISTRY_USER}" \
        --password-stdin \
        "${REGISTRY_HOST}"
fi

# ── Build ─────────────────────────────────────────────────────────────────────
case "${BUILDER}" in
  nixpacks)
    log "Building with Nixpacks → ${IMAGE_DEST}"
    # --out writes only the generated .nixpacks/ plan files (Dockerfile + .nix
    # files). It does NOT copy the app source. We copy .nixpacks/ back into the
    # workspace so the build context contains both the source and the plan files.
    nixpacks build . --out /tmp/nixpacks-out "${NIXPACKS_ENV_FLAGS[@]+"${NIXPACKS_ENV_FLAGS[@]}"}"
    cp -r /tmp/nixpacks-out/.nixpacks "${WORKDIR}/.nixpacks"
    # --layers enables intermediate layer caching in the PVC-backed OCI storage.
    # --cache-from uses the last successfully pushed image as the cache source.
    # This means stale intermediate layers from failed builds are never reused —
    # only layers from a real successful push are considered.
    buildah build \
        --layers \
        --cache-from "${IMAGE_DEST}" \
        --file "${WORKDIR}/.nixpacks/Dockerfile" \
        --tag "${IMAGE_DEST}" \
        "${WORKDIR}"
    ;;

  railpack)
    log "Building with Railpack → ${IMAGE_DEST}"
    # --output writes the Dockerfile + a copy of the app source into
    # /tmp/railpack-out. Use that directory as the build context.
    # Build env vars are exported into the environment so railpack picks them up.
    eval "${RAILPACK_EXPORTS}"
    railpack build . --generate-dockerfile --output /tmp/railpack-out
    buildah build \
        --layers \
        --cache-from "${IMAGE_DEST}" \
        --file /tmp/railpack-out/Dockerfile \
        --tag "${IMAGE_DEST}" \
        /tmp/railpack-out
    ;;

  dockerfile)
    log "Building with Dockerfile → ${IMAGE_DEST}"
    DOCKERFILE="${DOCKERFILE_PATH:-Dockerfile}"
    [[ -f "${DOCKERFILE}" ]] || die "Dockerfile not found at ${DOCKERFILE}"
    buildah build \
        --layers \
        --cache-from "${IMAGE_DEST}" \
        --file "${DOCKERFILE}" \
        --tag "${IMAGE_DEST}" \
        "${DOCKERFILE_BUILD_ARG_FLAGS[@]+"${DOCKERFILE_BUILD_ARG_FLAGS[@]}"}" \
        .
    ;;

  *)
    die "Unknown builder: ${BUILDER}. Valid values: nixpacks, railpack, dockerfile"
    ;;
esac

# ── Push ──────────────────────────────────────────────────────────────────────
log "Pushing ${IMAGE_DEST}…"
case "${BUILDER}" in
  nixpacks|railpack)
    buildah push "${IMAGE_DEST}" "docker://${IMAGE_DEST}"
    ;;
  dockerfile)
    buildah push "${IMAGE_DEST}" "docker://${IMAGE_DEST}"
    ;;
esac

log "Build complete: ${IMAGE_DEST}"
