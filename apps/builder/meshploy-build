#!/usr/bin/env bash
# Meshploy build script — runs inside the K8s builder Job container.
# Environment variables are injected by the K8s Job spec:
#   GIT_REPO       owner/repo
#   GIT_BRANCH     branch to build
#   GIT_TOKEN      GitHub installation access token
#   BUILDER        nixpacks | railpack | dockerfile
#   IMAGE_DEST     registry/image:tag to push to
#   REGISTRY_HOST  registry hostname (for buildah login)
#   REGISTRY_USER  registry username
#   REGISTRY_PASS  registry password

set -euo pipefail

log() { echo -e "\033[1;34m[meshploy-build]\033[0m $*"; }
die() { echo -e "\033[1;31m[meshploy-build] ERROR:\033[0m $*" >&2; exit 1; }

[[ -z "${GIT_REPO:-}"    ]] && die "GIT_REPO is not set"
[[ -z "${GIT_BRANCH:-}"  ]] && die "GIT_BRANCH is not set"
[[ -z "${GIT_TOKEN:-}"   ]] && die "GIT_TOKEN is not set"
[[ -z "${IMAGE_DEST:-}"  ]] && die "IMAGE_DEST is not set"
[[ -z "${REGISTRY_HOST:-}" ]] && die "REGISTRY_HOST is not set"

BUILDER="${BUILDER:-nixpacks}"
WORKDIR="/tmp/workspace"

# ── Parse build-time env vars ─────────────────────────────────────────────────
# BUILD_ENV_VARS is a newline-separated list of KEY=VALUE pairs.
# Build arrays of flags for each builder from the non-empty, non-comment lines.
NIXPACKS_ENV_FLAGS=()
RAILPACK_ENV_FLAGS=()
DOCKERFILE_BUILD_ARG_FLAGS=()

if [[ -n "${BUILD_ENV_VARS:-}" ]]; then
    while IFS= read -r line; do
        # Skip blank lines and comments
        [[ -z "$line" || "$line" == \#* ]] && continue
        key="${line%%=*}"
        value="${line#*=}"
        # Strip one layer of surrounding single or double quotes from the value.
        # Users often write KEY="value with spaces" — the quotes are shell syntax
        # and should not be part of the actual value passed to the build tool.
        if [[ ${#value} -ge 2 ]]; then
            first="${value:0:1}" last="${value: -1}"
            if [[ "$first" == '"' && "$last" == '"' ]] || \
               [[ "$first" == "'" && "$last" == "'" ]]; then
                value="${value:1:${#value}-2}"
            fi
        fi
        NIXPACKS_ENV_FLAGS+=(--env "${key}=${value}")
        RAILPACK_ENV_FLAGS+=(--env "${key}=${value}")
        DOCKERFILE_BUILD_ARG_FLAGS+=(--build-arg "${key}=${value}")
    done <<< "${BUILD_ENV_VARS}"
fi

# ── Clone ─────────────────────────────────────────────────────────────────────
log "Cloning ${GIT_REPO}@${GIT_BRANCH}…"
git clone --depth=1 --branch "${GIT_BRANCH}" \
    "https://x-access-token:${GIT_TOKEN}@github.com/${GIT_REPO}.git" \
    "${WORKDIR}"
cd "${WORKDIR}"
log "Cloned successfully ($(git rev-parse --short HEAD))"

# ── Mark registry as insecure if it is HTTP ──────────────────────────────────
# buildah defaults to HTTPS. Internal mesh registries (e.g. 100.64.x.x:5000)
# are plain HTTP — add them to registries.conf so buildah doesn't upgrade to TLS.
# This covers both `buildah push` and `buildah build --cache-from`.
mkdir -p "${HOME}/.config/containers"
cat >> "${HOME}/.config/containers/registries.conf" <<EOF

[[registry]]
location = "${REGISTRY_HOST}"
insecure = true
EOF

# ── Registry login ────────────────────────────────────────────────────────────
if [[ -n "${REGISTRY_USER:-}" && -n "${REGISTRY_PASS:-}" ]]; then
    log "Logging in to ${REGISTRY_HOST}…"
    echo "${REGISTRY_PASS}" | buildah login \
        --username "${REGISTRY_USER}" \
        --password-stdin \
        "${REGISTRY_HOST}"
    # Mirror credentials for BuildKit (used by railpack).
    # BuildKit reads ~/.docker/config.json, not buildah's auth.json.
    mkdir -p "${HOME}/.docker"
    echo "${REGISTRY_PASS}" | docker login \
        --username "${REGISTRY_USER}" \
        --password-stdin \
        "${REGISTRY_HOST}" 2>/dev/null || \
    printf '{"auths":{"%s":{"auth":"%s"}}}' \
        "${REGISTRY_HOST}" \
        "$(printf '%s:%s' "${REGISTRY_USER}" "${REGISTRY_PASS}" | base64 -w0)" \
        > "${HOME}/.docker/config.json"
fi

# ── Build ─────────────────────────────────────────────────────────────────────
# Strip tag to get the bare repo ref for --cache-from.
# Guard: if IMAGE_DEST has no tag (e.g. a registry with a port like
# host:5000/app) the naive %:* pattern would eat the port instead of the tag.
# Only strip when the final path component (after the last /) contains a colon.
_IMAGE_FINAL="${IMAGE_DEST##*/}"
if [[ "${_IMAGE_FINAL}" == *:* ]]; then
    CACHE_FROM_REPO="${IMAGE_DEST%:*}"
else
    CACHE_FROM_REPO="${IMAGE_DEST}"
fi
unset _IMAGE_FINAL

case "${BUILDER}" in
  nixpacks)
    log "Building with Nixpacks → ${IMAGE_DEST}"
    # --out writes only the generated .nixpacks/ plan files (Dockerfile + .nix
    # files). It does NOT copy the app source. We copy .nixpacks/ back into the
    # workspace so the build context contains both the source and the plan files.
    nixpacks build . --out /tmp/nixpacks-out "${NIXPACKS_ENV_FLAGS[@]+"${NIXPACKS_ENV_FLAGS[@]}"}"
    cp -r /tmp/nixpacks-out/.nixpacks "${WORKDIR}/.nixpacks"
    # --layers enables intermediate layer caching in the PVC-backed OCI storage.
    # --cache-from uses the last successfully pushed image as the cache source.
    # This means stale intermediate layers from failed builds are never reused —
    # only layers from a real successful push are considered.
    buildah build \
        --layers \
        --cache-from "${CACHE_FROM_REPO}" \
        --file "${WORKDIR}/.nixpacks/Dockerfile" \
        --tag "${IMAGE_DEST}" \
        "${WORKDIR}"
    ;;

  railpack)
    log "Building with Railpack → ${IMAGE_DEST}"
    # Railpack requires a BuildKit daemon. Start rootless buildkitd, wait for
    # the socket, then run railpack. --oci-worker-no-process-sandbox is required
    # in containers where full kernel namespace sandboxing is unavailable.
    BUILDKIT_SOCK="/tmp/buildkitd.sock"

    # Tell buildkitd the internal registry is plain HTTP (not HTTPS).
    mkdir -p /tmp/buildkit-config
    cat > /tmp/buildkit-config/buildkitd.toml <<EOF
[registry."${REGISTRY_HOST}"]
  http = true
  insecure = true
EOF

    start_buildkitd() {
        buildkitd \
            --addr "unix://${BUILDKIT_SOCK}" \
            --root "/tmp/buildkit-root" \
            --oci-worker-snapshotter=native \
            --config /tmp/buildkit-config/buildkitd.toml \
            2>/tmp/buildkitd.log &
        BUILDKITD_PID=$!
        for i in $(seq 1 30); do
            [ -S "${BUILDKIT_SOCK}" ] && break
            sleep 1
        done
    }

    export BUILDKIT_HOST="unix://${BUILDKIT_SOCK}"

    log "Starting buildkitd…"
    start_buildkitd
    [ -S "${BUILDKIT_SOCK}" ] || { cat /tmp/buildkitd.log; die "buildkitd socket not created"; }

    # Health-check: buildkitd socket can exist while it is still recovering
    # stale/corrupt PVC state from a previous cancelled build. Give it 10s to
    # respond; if it doesn't, wipe the state and restart clean.
    log "Checking buildkitd responsiveness…"
    BUILDKITD_OK=0
    for i in $(seq 1 10); do
        buildctl --addr "unix://${BUILDKIT_SOCK}" debug workers > /dev/null 2>&1 \
            && BUILDKITD_OK=1 && break
        sleep 1
    done

    if [ "${BUILDKITD_OK}" -eq 0 ]; then
        log "buildkitd unresponsive — clearing stale PVC state and restarting…"
        kill "${BUILDKITD_PID}" 2>/dev/null || true
        sleep 2
        rm -rf /tmp/buildkit-root/
        rm -f "${BUILDKIT_SOCK}"
        start_buildkitd
        [ -S "${BUILDKIT_SOCK}" ] || { cat /tmp/buildkitd.log; die "buildkitd failed after state reset"; }
        sleep 3
    fi

    # Railpack outputs a docker-format image tarball to stdout, preceded by
    # its build plan and progress text. Pipe through cat to drain stdout into
    # a temp file — this keeps the binary out of the K8s log pipe (which
    # drains too slowly and caused the "sending tarball" hang). Any progress
    # railpack writes to stderr remains visible in the build log.
    RAILPACK_RAW="/tmp/railpack-raw.bin"
    RAILPACK_TAR="/tmp/railpack-image.tar"
    railpack build . \
        --name "${IMAGE_DEST}" \
        --progress plain \
        "${RAILPACK_ENV_FLAGS[@]+"${RAILPACK_ENV_FLAGS[@]}"}" \
        | cat > "${RAILPACK_RAW}"

    kill "${BUILDKITD_PID}" 2>/dev/null || true

    # Locate the docker archive within the raw output by scanning forward in
    # 512-byte steps (tar block size) until tar validates the header.
    # Using tar itself is correct regardless of text prefix length, file
    # ordering inside the archive, or whether the user's build output contains
    # substrings like "manifest.json".
    log "Locating docker archive boundary…"
    TAR_OFFSET=0
    TAR_FOUND=0
    while [ "${TAR_OFFSET}" -lt 65536 ]; do
        if tail -c "+$((TAR_OFFSET + 1))" "${RAILPACK_RAW}" \
                | tar -t > /dev/null 2>&1; then
            TAR_FOUND=1
            break
        fi
        TAR_OFFSET=$((TAR_OFFSET + 512))
    done
    [ "${TAR_FOUND}" -eq 1 ] \
        || die "No valid docker archive in railpack output — build likely failed"

    if [ "${TAR_OFFSET}" -gt 0 ]; then
        log "Stripping ${TAR_OFFSET}-byte text prefix from railpack output…"
        tail -c "+$((TAR_OFFSET + 1))" "${RAILPACK_RAW}" > "${RAILPACK_TAR}"
        rm -f "${RAILPACK_RAW}"
    else
        mv "${RAILPACK_RAW}" "${RAILPACK_TAR}"
    fi
    ;;

  dockerfile)
    log "Building with Dockerfile → ${IMAGE_DEST}"
    DOCKERFILE="${DOCKERFILE_PATH:-Dockerfile}"
    [[ -f "${DOCKERFILE}" ]] || die "Dockerfile not found at ${DOCKERFILE}"
    buildah build \
        --layers \
        --cache-from "${CACHE_FROM_REPO}" \
        --file "${DOCKERFILE}" \
        --tag "${IMAGE_DEST}" \
        "${DOCKERFILE_BUILD_ARG_FLAGS[@]+"${DOCKERFILE_BUILD_ARG_FLAGS[@]}"}" \
        .
    ;;

  *)
    die "Unknown builder: ${BUILDER}. Valid values: nixpacks, railpack, dockerfile"
    ;;
esac

# ── Push ──────────────────────────────────────────────────────────────────────
# All three builders ultimately push via buildah.
# nixpacks/dockerfile: image is already in buildah's local store after `buildah build`.
# railpack: image was exported as a docker-format tar; load it first, then push.
# buildah uses registries.conf (written above) to reach HTTP registries.
case "${BUILDER}" in
  nixpacks|dockerfile)
    log "Pushing ${IMAGE_DEST}…"
    buildah push "${IMAGE_DEST}" "docker://${IMAGE_DEST}"
    ;;
  railpack)
    log "Loading railpack image into local store…"
    buildah pull "docker-archive:///tmp/railpack-image.tar"
    log "Pushing ${IMAGE_DEST}…"
    buildah push "${IMAGE_DEST}" "docker://${IMAGE_DEST}"
    ;;
esac

log "Build complete: ${IMAGE_DEST}"
